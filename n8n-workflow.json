{
  "name": "Alcovia Session Success Notification",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "alcovia-session-success",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "n1-webhook",
      "name": "Webhook — Session Success",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "alcovia-session-success"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/processed_notifications?session_id=eq.{{$json.body.session_id}}&select=session_id",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {},
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_ANON_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.SUPABASE_ANON_KEY}}"
            }
          ]
        }
      },
      "id": "n2-check-dedup",
      "name": "Check — Already Notified?",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{$json.length}}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "n3-if-new",
      "name": "IF — New Session?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/processed_notifications",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "session_id",
              "value": "={{$('Webhook — Session Success').item.json.body.session_id}}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_ANON_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.SUPABASE_ANON_KEY}}"
            },
            {
              "name": "Prefer",
              "value": "resolution=ignore-duplicates"
            }
          ]
        }
      },
      "id": "n4-insert-dedup",
      "name": "Insert — Mark Notified (ON CONFLICT IGNORE)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 200]
    },
    {
      "parameters": {
        "from": "={{$env.TWILIO_WHATSAPP_FROM}}",
        "to": "={{$env.TWILIO_WHATSAPP_TO}}",
        "message": "=🔥 Great focus session, {{$('Webhook — Session Success').item.json.body.student_id}}!\n\nStreak: {{$('Webhook — Session Success').item.json.body.streak_days}} days 🔥\nYou earned {{$('Webhook — Session Success').item.json.body.coins_awarded}} coins 🪙\nTotal coins: {{$('Webhook — Session Success').item.json.body.total_coins}} 🪙\n\nKeep it up! 💪"
      },
      "id": "n5-twilio",
      "name": "Twilio — Send WhatsApp",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [1120, 200],
      "credentials": {
        "twilioApi": {
          "id": "twilio-cred",
          "name": "Twilio account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://localhost:4000/api/v1/webhooks/n8n-log",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "sessionId",
              "value": "={{$('Webhook — Session Success').item.json.body.session_id}}"
            },
            {
              "name": "skipped",
              "value": false
            },
            {
              "name": "message",
              "value": "n8n webhook fired — WhatsApp sent"
            }
          ]
        },
        "options": {}
      },
      "id": "n6-log-fired",
      "name": "Log — Fired (Dev Panel)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1340, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://localhost:4000/api/v1/webhooks/n8n-log",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "sessionId",
              "value": "={{$('Webhook — Session Success').item.json.body.session_id}}"
            },
            {
              "name": "skipped",
              "value": true
            },
            {
              "name": "message",
              "value": "Skipped — already notified"
            }
          ]
        },
        "options": {}
      },
      "id": "n7-log-skipped",
      "name": "Log — Skipped (Dev Panel)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 400]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "n8-respond",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1560, 300]
    }
  ],
  "connections": {
    "Webhook — Session Success": {
