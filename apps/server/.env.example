# Alcovia Server — Environment Variables
# Copy this file to .env and fill in your values

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:3000

# ─── n8n Automation ──────────────────────────────────────────────────────────
# Get from: n8n Cloud → your workflow → Webhook trigger → copy URL
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/alcovia-session-success

# ─── Twilio WhatsApp Sandbox ─────────────────────────────────────────────────
# Get from: https://console.twilio.com → Messaging → Try it out → Send a WhatsApp message
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX
