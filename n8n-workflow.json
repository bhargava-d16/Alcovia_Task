  "_SETUP_NOTES": {
    "step1": "Import this file in n8n Cloud → Workflows → Import",
    "step2": "Set SUPABASE_URL and SUPABASE_ANON_KEY as n8n environment variables",
    "step3": "Create a Twilio credential in n8n with your Account SID and Auth Token",
    "step4": "Activate the workflow — copy the webhook URL to N8N_WEBHOOK_URL in apps/server/.env",
